{
  "name": "goroomz-backend",
  "version": "1.0.0",
  "description": "Backend API for GoRoomz room booking platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "setup": "node scripts/setup.js",
    "reset": "node scripts/resetDatabase.js",
    "seed": "node scripts/seedData.js",
    "createsuperuser": "node scripts/createSuperuser.js",
    "createsuperuser:quick": "node scripts/createSuperuserQuick.js",
    "checkuser": "node scripts/checkUser.js",
    "fix-permissions": "node scripts/updateUserPermissions.js",
    "test-email-fix": "node scripts/testEmailDotFix.js",
    "backup": "node scripts/backupDatabase.js",
    "restore": "node scripts/restoreDatabase.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:status": "sequelize-cli db:migrate:status",
    "migration:create": "sequelize-cli migration:generate --name"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.6.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "fast-check": "^4.3.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.3",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "room-booking",
    "api",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "GoRoomz Team",
  "license": "MIT"
}
