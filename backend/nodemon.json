{
  "watch": [
    "server.js",
    "routes",
    "controllers",
    "middleware",
    "models",
    "config",
    "services",
    "utils"
  ],
  "ext": "js,json",
  "ignore": [
    "node_modules",
    "logs",
    "*.log",
    "backups",
    "uploads",
    "migrations/*.js",
    "scripts/*.js",
    ".git"
  ],
  "delay": "1000",
  "verbose": true,
  "env": {
    "NODE_ENV": "development"
  }
}

